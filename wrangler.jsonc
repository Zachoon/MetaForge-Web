{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "metaforge-private-alpha",
  "main": "dist/server/index.js",
  "compatibility_date": "2026-07-14",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  },
  "workers_dev": true,
  "preview_urls": false,
  "vars": {
    "METAFORGE_BOOTSTRAP_LOCK": "unlocked",
    "METAFORGE_FOUNDER_USER_KEY": "f45237c471be9524242fb124700a61b6916cbbff9967c8ba74e43af0617bea90",
    "OPENAI_MODEL": "gpt-5.6-luna"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "metaforge-private-alpha-accounts",
      "database_id": "a16911c8-9a3a-4c97-bfe2-0ad68b19edf0",
      "migrations_dir": "migrations"
    }
  ]
}
